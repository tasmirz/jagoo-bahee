MONGODB_URI=mongodb://admin:secret@localhost:27017/
JWT_SECRET=your-super-secret-key-change-this
PORT=3000
# When running backend outside docker, use localhost:9000
# When running backend inside docker, use minio:9000
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=uploads
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
# Public URL that browsers can access (always localhost for local dev)
MINIO_PUBLIC_URL=http://localhost:9000
ADMIN_KEY=your-admin-key-change-this